# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Server ---
PORT=4000
NODE_ENV=development
# Comma-separated list of origins allowed to call this API (the frontend's URL)
CORS_ORIGIN=http://localhost:5173

# --- Database (MongoDB Atlas) ---
# Get this from Atlas: Cluster -> Connect -> Drivers -> copy connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/navin_sons?retryWrites=true&w=majority

# --- Auth (in-house JWT) ---
# Generate a fresh one per environment, e.g.: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- WhatsApp (Meta Graph API) ---
# Pull the real value from GCP Secret Manager (NS_WHATSAPP_TOKEN) in the old project
# before it's decommissioned — this app will no longer use Secret Manager, so the
# token lives as a plain env var here instead.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=613393411847158
WHATSAPP_API_VERSION=v21.0

# --- Dev safety net (mirrors the local-only override we added to the old backend) ---
# When set, ALL WhatsApp sends redirect here instead of the real recipient.
# Leave blank in production.
WHATSAPP_TEST_OVERRIDE_NUMBER=

# --- Image uploads (Cloudinary) ---
# Free account at cloudinary.com — Cloud Name / API Key / API Secret are on
# your dashboard homepage after signup.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Address autocomplete (Google Places API (New)) ---
# console.cloud.google.com -> enable "Places API (New)" -> Credentials ->
# Create API Key, restricted to that API. Requires billing enabled on the
# project, but real usage here (a couple of staff occasionally typing an
# address) stays nowhere near the free monthly quota (70,000 requests/mo
# for India). Leave blank to fall back to the free OpenStreetMap Nominatim
# lookup instead — see routes/geocode.routes.ts.
GOOGLE_PLACES_API_KEY=
